class Triangulo
{
private:
	float base;
	float altura;
public: //prototipos
	Triangulo(); //constructor
	~Triangulo(); //destructor
	float calculararea(float a, float b);
};

#include "Triangulo.h"
//Declaracion de metodos o funciones 

Triangulo::Triangulo() { //constructor
}
Triangulo::~Triangulo() {
}
float Triangulo::calculararea(float b, float h) {
	return (b * h) / 2;
}

