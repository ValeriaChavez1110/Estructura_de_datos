def factorial(n):
    if n == 0 or n == 1:
        return 1
    else:
        return n * factorial(n - 1)


def suma_cuadrados(n):
    if n == 1:
        return 1
    else:
        return n*n + suma_cuadrados(n - 1)


def serie(x, n):
    if n == 1:
        return x / factorial(1)
    else:
        return (x**n) / factorial(n)
